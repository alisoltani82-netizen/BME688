/**
 * BME688 + OLED Display with ESP32-C3 SuperMini
 * 
 * Wiring:
 *   BME688 (SPI):
 *     VCC  -> 3.3V
 *     GND  -> GND
 *     SCK  -> GPIO4
 *     SDI  -> GPIO6
 *     SDO  -> GPIO5
 *     CS   -> GPIO7
 * 
 *   OLED GME12864 (I2C):
 *     VCC  -> 3.3V
 *     GND  -> GND
 *     SDA  -> GPIO8
 *     SCL  -> GPIO9
 */

#include <Arduino.h>
#include <SPI.h>
#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME680.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// BME688 SPI pins
#define BME_SCK   4
#define BME_MOSI  6
#define BME_MISO  5
#define BME_CS    7

// OLED I2C pins
#define OLED_SDA  8
#define OLED_SCL  9

// OLED display settings
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1  // No reset pin
#define OLED_I2C_ADDR 0x3C  // Common address (try 0x3D if not working)

#define SEALEVELPRESSURE_HPA (1013.25)

// Create instances
Adafruit_BME680 bme(BME_CS, BME_MOSI, BME_MISO, BME_SCK);
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

bool sensorFound = false;
bool displayFound = false;

// Air quality rating based on gas resistance
const char* getAirQuality(float gasResistance) {
    float kohm = gasResistance / 1000.0;
    if (kohm > 100) return "Excellent";
    if (kohm > 50) return "Good";
    if (kohm > 25) return "Moderate";
    if (kohm > 10) return "Poor";
    return "Bad";
}

void displayReadings(float temp, float humidity, float pressure, float altitude, float gasRes) {
    display.clearDisplay();
    
    // Title bar
    display.fillRect(0, 0, 128, 12, SSD1306_WHITE);
    display.setTextColor(SSD1306_BLACK);
    display.setTextSize(1);
    display.setCursor(4, 2);
    display.print("BME688 Air Monitor");
    
    display.setTextColor(SSD1306_WHITE);
    
    // Temperature - larger font
    display.setTextSize(2);
    display.setCursor(0, 16);
    display.print(temp, 1);
    display.setTextSize(1);
    display.print("C");
    
    // Humidity
    display.setTextSize(2);
    display.setCursor(75, 16);
    display.print(humidity, 0);
    display.setTextSize(1);
    display.print("%");
    
    // Divider line
    display.drawLine(0, 34, 128, 34, SSD1306_WHITE);
    
    // Pressure and Altitude on same line
    display.setTextSize(1);
    display.setCursor(0, 38);
    display.print(pressure / 100.0, 0);
    display.print("hPa ");
    display.print(altitude, 0);
    display.print("m");
    
    // Gas resistance
    display.setCursor(0, 48);
    display.print("Gas: ");
    display.print(gasRes / 1000.0, 1);
    display.print("kOhm ");
    display.print(getAirQuality(gasRes));
    
    display.display();
}

void displayError(const char* msg) {
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(SSD1306_WHITE);
    display.setCursor(0, 0);
    display.println("ERROR:");
    display.println();
    display.println(msg);
    display.display();
}

void displayStartup() {
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(SSD1306_WHITE);
    display.setCursor(10, 10);
    display.println("BME688 + OLED");
    display.setCursor(10, 25);
    display.println("Initializing...");
    display.display();
}

void setup() {
    Serial.begin(115200);
    delay(2000);
    
    Serial.println();
    Serial.println("=================================");
    Serial.println("BME688 + OLED Display");
    Serial.println("ESP32-C3 SuperMini");
    Serial.println("=================================");
    
    // Initialize I2C for OLED
    Wire.begin(OLED_SDA, OLED_SCL);
    
    // Initialize OLED
    if (!display.begin(SSD1306_SWITCHCAPVCC, OLED_I2C_ADDR)) {
        Serial.println("OLED not found! Check wiring.");
        Serial.println("  SDA -> GPIO8");
        Serial.println("  SCL -> GPIO9");
        displayFound = false;
    } else {
        Serial.println("OLED found!");
        displayFound = true;
        displayStartup();
    }
    
    delay(500);
    
    // Initialize BME688
    if (!bme.begin()) {
        Serial.println("BME688 not found! Check wiring.");
        if (displayFound) {
            displayError("BME688 not found!\nCheck SPI wiring.");
        }
        sensorFound = false;
    } else {
        Serial.println("BME688 found!");
        sensorFound = true;
        
        // Configure sensor
        bme.setTemperatureOversampling(BME680_OS_8X);
        bme.setHumidityOversampling(BME680_OS_2X);
        bme.setPressureOversampling(BME680_OS_4X);
        bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
        bme.setGasHeater(320, 150);
    }
    
    if (displayFound && sensorFound) {
        display.clearDisplay();
        display.setCursor(20, 25);
        display.println("Ready!");
        display.display();
        delay(1000);
    }
    
    Serial.println();
}

void loop() {
    if (!sensorFound) {
        // Try to reinitialize
        if (bme.begin()) {
            sensorFound = true;
            bme.setTemperatureOversampling(BME680_OS_8X);
            bme.setHumidityOversampling(BME680_OS_2X);
            bme.setPressureOversampling(BME680_OS_4X);
            bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
            bme.setGasHeater(320, 150);
        } else {
            delay(5000);
            return;
        }
    }
    
    // Perform reading
    if (!bme.performReading()) {
        Serial.println("Failed to read sensor!");
        if (displayFound) {
            displayError("Sensor read failed!");
        }
        delay(2000);
        return;
    }
    
    // Get readings
    float temp = bme.temperature;
    float humidity = bme.humidity;
    float pressure = bme.pressure;
    float gasRes = bme.gas_resistance;
    float altitude = bme.readAltitude(SEALEVELPRESSURE_HPA);
    
    // Update OLED
    if (displayFound) {
        displayReadings(temp, humidity, pressure, altitude, gasRes);
    }
    
    // Print to Serial
    Serial.println("--- Sensor Reading ---");
    Serial.print("Temperature: "); Serial.print(temp); Serial.println(" °C");
    Serial.print("Humidity: "); Serial.print(humidity); Serial.println(" %");
    Serial.print("Pressure: "); Serial.print(pressure / 100.0); Serial.println(" hPa");
    Serial.print("Altitude: "); Serial.print(altitude); Serial.println(" m");
    Serial.print("Gas: "); Serial.print(gasRes / 1000.0); Serial.println(" kOhm");
    Serial.print("Air Quality: "); Serial.println(getAirQuality(gasRes));
    Serial.println();
    
    delay(2000); // Update every 2 seconds
}
