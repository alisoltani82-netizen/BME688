/**
 * BME688 Basic Example (without BSEC)
 * 
 * This is a simpler alternative using the basic Adafruit BME680 library.
 * Use this if you don't need the advanced IAQ features from BSEC.
 * 
 * Wiring:
 *   BME688 VCC  -> 3.3V
 *   BME688 GND  -> GND
 *   BME688 SDA  -> GPIO8
 *   BME688 SCL  -> GPIO9
 */

#include <Arduino.h>
#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME680.h>

// I2C pins for ESP32-C3 SuperMini
#define SDA_PIN 8
#define SCL_PIN 9

// Sea level pressure for altitude calculation (adjust for your location)
#define SEALEVELPRESSURE_HPA (1013.25)

Adafruit_BME680 bme;

void setup() {
    Serial.begin(115200);
    delay(1000);
    
    Serial.println();
    Serial.println("=================================");
    Serial.println("BME688 Basic Sensor Demo");
    Serial.println("ESP32-C3 SuperMini");
    Serial.println("=================================");
    Serial.println();

    // Initialize I2C with custom pins
    Wire.begin(SDA_PIN, SCL_PIN);

    // Initialize BME688
    if (!bme.begin(0x77, &Wire)) {
        // Try alternate address
        if (!bme.begin(0x76, &Wire)) {
            Serial.println("Could not find BME688 sensor!");
            Serial.println("Check wiring:");
            Serial.println("  VCC -> 3.3V");
            Serial.println("  GND -> GND");
            Serial.println("  SDA -> GPIO8");
            Serial.println("  SCL -> GPIO9");
            while (1) {
                delay(1000);
            }
        }
    }

    Serial.println("BME688 sensor found!");

    // Set up oversampling and filter
    bme.setTemperatureOversampling(BME680_OS_8X);
    bme.setHumidityOversampling(BME680_OS_2X);
    bme.setPressureOversampling(BME680_OS_4X);
    bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
    bme.setGasHeater(320, 150); // 320°C for 150 ms

    Serial.println("Sensor configured!");
    Serial.println();
}

void loop() {
    // Perform a reading
    if (!bme.performReading()) {
        Serial.println("Failed to perform reading!");
        delay(2000);
        return;
    }

    Serial.println("--- Sensor Reading ---");
    
    // Temperature
    Serial.print("Temperature: ");
    Serial.print(bme.temperature);
    Serial.println(" °C");
    
    // Humidity
    Serial.print("Humidity: ");
    Serial.print(bme.humidity);
    Serial.println(" %");
    
    // Pressure
    Serial.print("Pressure: ");
    Serial.print(bme.pressure / 100.0);
    Serial.println(" hPa");
    
    // Altitude (estimated)
    Serial.print("Altitude: ");
    Serial.print(bme.readAltitude(SEALEVELPRESSURE_HPA));
    Serial.println(" m");
    
    // Gas resistance
    Serial.print("Gas Resistance: ");
    Serial.print(bme.gas_resistance / 1000.0);
    Serial.println(" kOhm");
    
    Serial.println();
    
    delay(3000); // Read every 3 seconds
}
