/**
 * BME688 + OLED Display with ESP32-C3 SuperMini
 * 
 * Wiring:
 *   BME688 (SPI):
 *     VCC  -> 3.3V
 *     GND  -> GND
 *     SCK  -> GPIO4
 *     SDI  -> GPIO6
 *     SDO  -> GPIO5
 *     CS   -> GPIO7
 * 
 *   OLED GME12864 (I2C):
 *     VCC  -> 3.3V
 *     GND  -> GND
 *     SDA  -> GPIO8
 *     SCL  -> GPIO9
 */

#include <Arduino.h>
#include <SPI.h>
#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME680.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// BME688 SPI pins
#define BME_SCK   4
#define BME_MOSI  6
#define BME_MISO  5
#define BME_CS    7

// OLED I2C pins
#define OLED_SDA  8
#define OLED_SCL  9

// OLED display settings
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1  // No reset pin
#define OLED_I2C_ADDR 0x3C  // Common address (try 0x3D if not working)

#define SEALEVELPRESSURE_HPA (1013.25)

// Create instances
Adafruit_BME680 bme(BME_CS, BME_MOSI, BME_MISO, BME_SCK);
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

bool sensorFound = false;
bool displayFound = false;

// Baseline tracking for air quality estimation
float gasBaseline = 50000.0;  // Initial baseline (will be calibrated)
float humidityBaseline = 40.0;
bool baselineCalibrated = false;
unsigned long startTime = 0;
unsigned long sampleCount = 0;
float gasSum = 0;

// Calculate IAQ-like score (0-500, lower is better)
// This is a simplified estimation without BSEC
int calculateAirQualityIndex(float gasRes, float humidity) {
    // Humidity compensation (gas sensor is affected by humidity)
    float humidityFactor = 1.0;
    if (humidity > 80) {
        humidityFactor = 0.8;  // High humidity reduces accuracy
    } else if (humidity < 20) {
        humidityFactor = 0.9;
    }
    
    // Calculate ratio to baseline
    float ratio = gasBaseline / gasRes;
    
    // Convert to IAQ-like scale (0-500)
    // ratio > 1 means worse air (lower resistance than baseline)
    // ratio < 1 means better air (higher resistance than baseline)
    int iaq;
    if (ratio <= 0.5) {
        iaq = 0;  // Excellent - much better than baseline
    } else if (ratio <= 1.0) {
        iaq = (int)((ratio - 0.5) * 100);  // 0-50 Good range
    } else if (ratio <= 2.0) {
        iaq = 50 + (int)((ratio - 1.0) * 100);  // 50-150
    } else if (ratio <= 4.0) {
        iaq = 150 + (int)((ratio - 2.0) * 75);  // 150-300
    } else {
        iaq = 300 + (int)((ratio - 4.0) * 50);  // 300-500
    }
    
    // Apply humidity factor and clamp
    iaq = (int)(iaq * humidityFactor);
    if (iaq < 0) iaq = 0;
    if (iaq > 500) iaq = 500;
    
    return iaq;
}

// Air quality rating based on IAQ score
const char* getAirQualityFromIAQ(int iaq) {
    if (iaq <= 50) return "Excellent";
    if (iaq <= 100) return "Good";
    if (iaq <= 150) return "Light";
    if (iaq <= 200) return "Moderate";
    if (iaq <= 250) return "Heavy";
    if (iaq <= 350) return "Severe";
    return "Extreme";
}

// Simple air quality rating based on gas resistance
const char* getAirQuality(float gasResistance) {
    float kohm = gasResistance / 1000.0;
    if (kohm > 100) return "Excellent";
    if (kohm > 50) return "Good";
    if (kohm > 25) return "Moderate";
    if (kohm > 10) return "Poor";
    return "Bad";
}

// Estimate CO2 equivalent (very rough approximation)
int estimateCO2(float gasRes, float humidity) {
    // This is a rough estimation - BSEC does this much better
    // Baseline CO2 is ~400-450 ppm outdoors
    float ratio = gasBaseline / gasRes;
    int co2 = 400 + (int)((ratio - 0.5) * 800);
    if (co2 < 400) co2 = 400;
    if (co2 > 5000) co2 = 5000;
    return co2;
}

void displayReadings(float temp, float humidity, float pressure, float altitude, float gasRes) {
    // Update baseline (calibrate over first 5 minutes with running average)
    sampleCount++;
    gasSum += gasRes;
    unsigned long elapsed = millis() - startTime;
    
    if (elapsed < 300000) {  // First 5 minutes
        gasBaseline = gasSum / sampleCount;  // Running average
    } else if (!baselineCalibrated) {
        baselineCalibrated = true;
        Serial.println(">>> Baseline calibrated! <<<");
    }
    
    int iaq = calculateAirQualityIndex(gasRes, humidity);
    int co2 = estimateCO2(gasRes, humidity);
    
    display.clearDisplay();
    
    // Title bar with IAQ
    display.fillRect(0, 0, 128, 12, SSD1306_WHITE);
    display.setTextColor(SSD1306_BLACK);
    display.setTextSize(1);
    display.setCursor(2, 2);
    display.print("IAQ:");
    display.print(iaq);
    display.print(" ");
    display.print(getAirQualityFromIAQ(iaq));
    
    // Calibration indicator
    display.setCursor(108, 2);
    if (baselineCalibrated) {
        display.print("***");
    } else {
        int dots = (elapsed / 100000) + 1;  // Progress indicator
        for (int i = 0; i < 3; i++) {
            display.print(i < dots ? "*" : ".");
        }
    }
    
    display.setTextColor(SSD1306_WHITE);
    
    // Temperature - larger font
    display.setTextSize(2);
    display.setCursor(0, 16);
    display.print(temp, 1);
    display.setTextSize(1);
    display.print("C");
    
    // Humidity
    display.setTextSize(2);
    display.setCursor(75, 16);
    display.print(humidity, 0);
    display.setTextSize(1);
    display.print("%");
    
    // Divider line
    display.drawLine(0, 34, 128, 34, SSD1306_WHITE);
    
    // Pressure and Altitude on same line
    display.setTextSize(1);
    display.setCursor(0, 38);
    display.print(pressure / 100.0, 0);
    display.print("hPa ");
    display.print(altitude, 0);
    display.print("m");
    
    // CO2 estimate and Gas resistance
    display.setCursor(0, 48);
    display.print("CO2:");
    display.print(co2);
    display.print(" Gas:");
    display.print(gasRes / 1000.0, 1);
    display.print("k");
    
    display.display();
}

void displayError(const char* msg) {
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(SSD1306_WHITE);
    display.setCursor(0, 0);
    display.println("ERROR:");
    display.println();
    display.println(msg);
    display.display();
}

void displayStartup() {
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(SSD1306_WHITE);
    display.setCursor(10, 10);
    display.println("BME688 + OLED");
    display.setCursor(10, 25);
    display.println("Initializing...");
    display.display();
}

void setup() {
    Serial.begin(115200);
    delay(2000);
    
    Serial.println();
    Serial.println("=================================");
    Serial.println("BME688 + OLED Display");
    Serial.println("ESP32-C3 SuperMini");
    Serial.println("=================================");
    
    // Initialize I2C for OLED
    Wire.begin(OLED_SDA, OLED_SCL);
    
    // Initialize OLED
    if (!display.begin(SSD1306_SWITCHCAPVCC, OLED_I2C_ADDR)) {
        Serial.println("OLED not found! Check wiring.");
        Serial.println("  SDA -> GPIO8");
        Serial.println("  SCL -> GPIO9");
        displayFound = false;
    } else {
        Serial.println("OLED found!");
        displayFound = true;
        displayStartup();
    }
    
    delay(500);
    
    // Initialize BME688
    if (!bme.begin()) {
        Serial.println("BME688 not found! Check wiring.");
        if (displayFound) {
            displayError("BME688 not found!\nCheck SPI wiring.");
        }
        sensorFound = false;
    } else {
        Serial.println("BME688 found!");
        sensorFound = true;
        
        // Configure sensor
        bme.setTemperatureOversampling(BME680_OS_8X);
        bme.setHumidityOversampling(BME680_OS_2X);
        bme.setPressureOversampling(BME680_OS_4X);
        bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
        bme.setGasHeater(320, 150);
    }
    
    if (displayFound && sensorFound) {
        display.clearDisplay();
        display.setCursor(20, 25);
        display.println("Ready!");
        display.display();
        delay(1000);
    }
    
    // Initialize start time for baseline calibration
    startTime = millis();
    
    Serial.println();
}

void loop() {
    if (!sensorFound) {
        // Try to reinitialize
        if (bme.begin()) {
            sensorFound = true;
            bme.setTemperatureOversampling(BME680_OS_8X);
            bme.setHumidityOversampling(BME680_OS_2X);
            bme.setPressureOversampling(BME680_OS_4X);
            bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
            bme.setGasHeater(320, 150);
        } else {
            delay(5000);
            return;
        }
    }
    
    // Perform reading
    if (!bme.performReading()) {
        Serial.println("Failed to read sensor!");
        if (displayFound) {
            displayError("Sensor read failed!");
        }
        delay(2000);
        return;
    }
    
    // Get readings
    float temp = bme.temperature;
    float humidity = bme.humidity;
    float pressure = bme.pressure;
    float gasRes = bme.gas_resistance;
    float altitude = bme.readAltitude(SEALEVELPRESSURE_HPA);
    
    // Update OLED
    if (displayFound) {
        displayReadings(temp, humidity, pressure, altitude, gasRes);
    }
    
    // Calculate IAQ and CO2 for serial output
    int iaq = calculateAirQualityIndex(gasRes, humidity);
    int co2 = estimateCO2(gasRes, humidity);
    
    // Print to Serial
    Serial.println("--- Sensor Reading ---");
    Serial.print("Temperature: "); Serial.print(temp); Serial.println(" °C");
    Serial.print("Humidity: "); Serial.print(humidity); Serial.println(" %");
    Serial.print("Pressure: "); Serial.print(pressure / 100.0); Serial.println(" hPa");
    Serial.print("Altitude: "); Serial.print(altitude); Serial.println(" m");
    Serial.print("Gas Resistance: "); Serial.print(gasRes / 1000.0); Serial.println(" kOhm");
    Serial.print("IAQ Score: "); Serial.print(iaq); Serial.print(" ("); Serial.print(getAirQualityFromIAQ(iaq)); Serial.println(")");
    Serial.print("Est. CO2: "); Serial.print(co2); Serial.println(" ppm");
    Serial.print("Baseline Calibrated: "); Serial.println(baselineCalibrated ? "Yes" : "No");
    Serial.println();
    
    delay(2000); // Update every 2 seconds
}
